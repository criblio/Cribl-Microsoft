# Logs (root-anchored: source directories may legitimately be named "logs",
# e.g. packages/ui/src/screens/logs; runtime log data lives under
# apps/local-app/data/, ignored by that app's own .gitignore)
/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Build outputs
build/
package-build/
