<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required for Electron to load JIT-compiled JS -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Required for Electron native modules (v8 inspectors etc.) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Allow reading files outside the app bundle (user data in ~/Library/Application Support) -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <!-- Network access for GitHub API fetches, Cribl / Azure API calls -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Allow DYLD environment variables (needed for some Electron versions on macOS) -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
</dict>
</plist>
