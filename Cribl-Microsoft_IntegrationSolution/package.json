{
  "name": "cribl-microsoft-integration",
  "version": "1.0.0",
  "description": "Cribl SOC Optimization Toolkit for Microsoft Sentinel",
  "main": "dist-electron/main/main.js",
  "author": "James Pederson",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "dev:web": "concurrently \"vite --config vite.config.web.ts\" \"npx tsx src/server/index.ts\"",
    "server": "npx tsx src/server/index.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:uat": "npx tsx --tsconfig tsconfig.server.json tests/test-uat-crowdstrike.ts",
    "typecheck": "tsc --noEmit",
    "validate": "tsc --noEmit && vitest run",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis portable",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.60.0",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "multer": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/multer": "^2.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.2"
  },
  "build": {
    "appId": "com.cribl.microsoft-integration",
    "productName": "Cribl SOC Optimization Toolkit",
    "copyright": "Copyright (c) 2026 Cribl",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "!**/*.ts",
      "!**/*.map",
      "!tests/**/*",
      "!node_modules/**/*.md",
      "!node_modules/**/*.markdown",
      "!node_modules/**/LICENSE*",
      "!node_modules/**/README*",
      "!node_modules/**/CHANGELOG*"
    ],
    "extraMetadata": {
      "main": "dist-electron/main/main.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "signingHashAlgorithms": [
        "sha256"
      ],
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Cribl SOC Toolkit",
      "runAfterFinish": false,
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "publish": null
  }
}
